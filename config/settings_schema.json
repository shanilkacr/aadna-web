[
  {
    "name": "theme_info",
    "theme_name": "AADNA",
    "theme_version": "1.0.0",
    "theme_author": "AADNA",
    "theme_documentation_url": "https://aadna.store",
    "theme_support_email": "support@aadna.store"
  },
  {
    "name": "Logo",
    "settings": [
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo image (black, used on light backgrounds)"
      },
      {
        "type": "image_picker",
        "id": "logo_alt",
        "label": "Logo image (gold, used in footer / dark backgrounds)"
      },
      {
        "type": "range",
        "id": "logo_width",
        "min": 80,
        "max": 300,
        "step": 10,
        "default": 150,
        "unit": "px",
        "label": "Logo width"
      },
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon"
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_background",
        "label": "Background",
        "default": "#FBF8F4"
      },
      {
        "type": "color",
        "id": "color_background_alt",
        "label": "Secondary background",
        "default": "#F2ECE2"
      },
      {
        "type": "color",
        "id": "color_text",
        "label": "Text",
        "default": "#2B2620"
      },
      {
        "type": "color",
        "id": "color_text_muted",
        "label": "Muted text",
        "default": "#7A7264"
      },
      {
        "type": "color",
        "id": "color_accent",
        "label": "Accent (gold)",
        "default": "#AD8A54"
      },
      {
        "type": "color",
        "id": "color_border",
        "label": "Border",
        "default": "#E6DDCE"
      },
      {
        "type": "color",
        "id": "color_button_background",
        "label": "Button background",
        "default": "#2B2620"
      },
      {
        "type": "color",
        "id": "color_button_text",
        "label": "Button text",
        "default": "#FBF8F4"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
        "default": "jost_n4"
      },
      {
        "type": "font_picker",
        "id": "font_body",
        "label": "Body font",
        "default": "assistant_n4"
      },
      {
        "type": "range",
        "id": "heading_letter_spacing",
        "min": 0,
        "max": 6,
        "step": 1,
        "default": 1,
        "unit": "px",
        "label": "Heading letter spacing"
      }
    ]
  },
  {
    "name": "Layout",
    "settings": [
      {
        "type": "range",
        "id": "page_width",
        "min": 1000,
        "max": 1600,
        "step": 20,
        "default": 1400,
        "unit": "px",
        "label": "Page width"
      },
      {
        "type": "range",
        "id": "spacing_sections",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 72,
        "unit": "px",
        "label": "Space between sections"
      },
      {
        "type": "range",
        "id": "grid_gap",
        "min": 4,
        "max": 48,
        "step": 4,
        "default": 12,
        "unit": "px",
        "label": "Grid spacing"
      }
    ]
  },
  {
    "name": "Buttons",
    "settings": [
      {
        "type": "range",
        "id": "button_border_radius",
        "min": 0,
        "max": 40,
        "step": 1,
        "default": 0,
        "unit": "px",
        "label": "Button corner radius"
      }
    ]
  },
  {
    "name": "Cart",
    "settings": [
      {
        "type": "select",
        "id": "cart_type",
        "label": "Cart type",
        "default": "drawer",
        "options": [
          { "value": "drawer", "label": "Drawer" },
          { "value": "page", "label": "Page" }
        ]
      }
    ]
  },
  {
    "name": "Social media",
    "settings": [
      { "type": "text", "id": "social_instagram", "label": "Instagram URL" },
      { "type": "text", "id": "social_facebook", "label": "Facebook URL" },
      { "type": "text", "id": "social_tiktok", "label": "TikTok URL" }
    ]
  }
]
