{%- comment -%}
  Off-canvas mobile menu, slides in from the left.
  Rendered once by sections/header.liquid; opened by any [data-menu-toggle] button.
  Accepts:
    menu         - main linklist (section.settings.menu)
    mega_trigger - title of the item that expands to show product types (section.settings.mega_menu_trigger)
{%- endcomment -%}
<div class="menu-drawer" id="MenuDrawer" aria-hidden="true">
  <div class="menu-drawer__overlay" data-menu-drawer-close></div>
  <div class="menu-drawer__panel" role="dialog" aria-modal="true" aria-label="{{ 'sections.header.menu' | t }}">
    <div class="menu-drawer__header">
      <button type="button" class="menu-drawer__close" data-menu-drawer-close aria-label="{{ 'general.cart.close' | t }}">{% render 'icon-close' %}</button>
    </div>
    <nav class="menu-drawer__nav">
      <ul>
        {% render 'main-nav-items',
          menu: menu,
          mega_trigger: mega_trigger,
          variant: 'drawer'
        %}
      </ul>
    </nav>
    <div class="menu-drawer__footer">
      <a href="{{ routes.account_url }}">{{ 'sections.header.account' | t }}</a>
    </div>
  </div>
</div>
