{%- comment -%}
  Renders the inner header markup. Accepts: variant ('default' | 'transparent' | 'solid')
  - default: gold logo at 80% size, dark text — same styling/sizing/spacing as the
    on-scroll (solid) homepage header. Used on non-hero pages (always visible, not fixed).
  - transparent: gold logo, full size, white text, overlays the hero (scrolls away, not fixed)
  - solid: gold logo at 80% size, dark text, slides in fixed once scrolled
{%- endcomment -%}
<div class="page-width site-header__inner">
  <div class="site-header__start">
    <button type="button" class="site-header__menu-toggle" data-menu-toggle aria-label="{{ 'sections.header.menu' | t }}">
      {% render 'icon-menu' %}
    </button>
    <button type="button" class="site-header__icon" data-search-toggle aria-label="{{ 'general.search.submit' | t }}">
      <span class="site-header__search-icon site-header__search-icon--search">{% render 'icon-search' %}</span>
      <span class="site-header__search-icon site-header__search-icon--close">{% render 'icon-close' %}</span>
    </button>
  </div>

  <a href="{{ routes.root_url }}" class="site-header__logo" style="width:{{ settings.logo_width }}px;">
    {%- if variant == 'transparent' -%}
      {% render 'logo', variant: variant, class: 'site-header__logo-img', width: settings.logo_width %}
    {%- else -%}
      {% render 'logo', variant: 'solid', class: 'site-header__logo-img site-header__logo-img--scrolled', width: settings.logo_width %}
    {%- endif -%}
  </a>

  <nav class="site-header__nav" data-nav>
    <ul>
      {%- assign mega_trigger = section.settings.mega_menu_trigger | downcase -%}
      {%- for link in section.settings.menu.links -%}
        {%- assign link_title_down = link.title | downcase -%}
        {%- if mega_trigger != blank and link_title_down == mega_trigger -%}
          <li class="site-header__nav-item site-header__nav-item--mega" data-mega-trigger>
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {%- else -%}
          <li class="site-header__nav-item">
            <a href="{{ link.url }}">{{ link.title }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </nav>

  <div class="site-header__end">
    <a href="{{ routes.account_url }}" class="site-header__icon" aria-label="{{ 'sections.header.account' | t }}">
      {% render 'icon-account' %}
    </a>
    <button type="button" class="site-header__icon site-header__cart" data-cart-toggle aria-label="{{ 'sections.header.cart' | t }}">
      {% render 'icon-cart' %}
      {%- if cart.item_count > 0 -%}
        <span class="site-header__cart-count">{{ cart.item_count }}</span>
      {%- endif -%}
    </button>
  </div>
</div>

{%- if section.settings.mega_menu_trigger != blank -%}
  {% render 'mega-menu', section: section %}
{%- endif -%}
