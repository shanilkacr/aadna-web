{%- comment -%}
  Renders a single "Shop by Collection" style tile — the standard collection
  card design used site-wide (homepage Shop by Collection section, and the
  /collections/all page).

  Accepts:
    collection      - collection object (required for the real link/title/image fallback)
    title           - text override for the title (optional)
    image           - image object override (optional)
    video           - video object override, takes priority over image (optional)
    fallback_image  - text URL or bundled theme asset filename, used only if no
                       collection/image/video is available (optional)
{%- endcomment -%}
{%- liquid
  assign display_title = title | default: collection.title
  assign display_link = collection.url | default: '#'
-%}
<div class="collection-list__item">
  <div class="collection-list__media">
    {%- if video != blank -%}
      {{ video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
    {%- elsif image != blank -%}
      <img
        src="{{ image | image_url: width: 1200 }}"
        alt="{{ display_title | escape }}"
        loading="lazy"
        width="1200"
        height="{{ 1200 | divided_by: image.aspect_ratio | default: 1200 }}"
      >
    {%- elsif collection.featured_image -%}
      <img
        src="{{ collection.featured_image | image_url: width: 1200 }}"
        alt="{{ collection.title | escape }}"
        loading="lazy"
        width="1200"
        height="{{ 1200 | divided_by: collection.featured_image.aspect_ratio | default: 1200 }}"
      >
    {%- elsif fallback_image != blank and fallback_image contains '://' -%}
      <img src="{{ fallback_image }}" alt="{{ display_title | escape }}" loading="lazy" width="1200" height="1200">
    {%- elsif fallback_image != blank -%}
      <img src="{{ fallback_image | asset_url }}" alt="{{ display_title | escape }}" loading="lazy" width="1200" height="1200">
    {%- endif -%}
  </div>
  <div class="collection-list__overlay"></div>
  <div class="collection-list__content">
    <h2 class="collection-list__title">{{ display_title }}</h2>
    <a href="{{ display_link }}" class="collection-list__cta">{{ 'collections.general.explore' | t }}</a>
  </div>
</div>
