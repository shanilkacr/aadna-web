<ul class="social-icons">
  {% if settings.social_instagram != blank %}
    <li><a href="{{ settings.social_instagram }}" aria-label="Instagram" target="_blank" rel="noopener">Instagram</a></li>
  {% endif %}
  {% if settings.social_facebook != blank %}
    <li><a href="{{ settings.social_facebook }}" aria-label="Facebook" target="_blank" rel="noopener">Facebook</a></li>
  {% endif %}
  {% if settings.social_tiktok != blank %}
    <li><a href="{{ settings.social_tiktok }}" aria-label="TikTok" target="_blank" rel="noopener">TikTok</a></li>
  {% endif %}
</ul>
