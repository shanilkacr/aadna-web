<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{ shop.name }}</title>
  {{ content_for_header }}
  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ settings.font_heading | font_face: font_display: 'swap' }}
  {{ settings.font_body | font_face: font_display: 'swap' }}
  <style>
    :root{
      --color-background: {{ settings.color_background }};
      --color-text: {{ settings.color_text }};
      --color-accent: {{ settings.color_accent }};
      --font-heading: {{ settings.font_heading.family }}, {{ settings.font_heading.fallback_families }};
      --font-body: {{ settings.font_body.family }}, {{ settings.font_body.fallback_families }};
    }
    body.password-page{
      min-height:100vh;display:flex;align-items:center;justify-content:center;flex-direction:column;
      background:var(--color-background);color:var(--color-text);font-family:var(--font-body);text-align:center;padding:24px;
    }
    .password-page h1{font-family:var(--font-heading);letter-spacing:2px;text-transform:uppercase;font-size:28px;margin-bottom:16px;}
    .password-page form{margin-top:24px;display:flex;gap:8px;}
    .password-page input[type="password"]{padding:12px 4px;border:none;border-bottom:1px solid var(--color-border, #ddd);border-radius:0;background:transparent;}
    .password-page input[type="password"]:focus{outline:none;border-bottom-color:var(--color-text);}
    .password-page button{padding:12px 20px;background:var(--color-accent);color:#fff;border:none;cursor:pointer;text-transform:uppercase;letter-spacing:1px;font-size:12px;}
  </style>
</head>
<body class="password-page">
  {% if settings.logo %}
    <img src="{{ settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="150" height="{{ 150 | divided_by: settings.logo.aspect_ratio | default: 150 }}" style="height:auto;">
  {% else %}
    <img src="{{ 'logo-black.png' | asset_url }}" alt="{{ shop.name }}" width="150" height="{{ 150 | times: 197 | divided_by: 924 }}" style="height:auto;">
  {% endif %}

  <p>{{ 'general.password_page.opening_soon' | t }}</p>

  {{ content_for_layout }}
</body>
</html>
