<section class="press-strip page-width" style="padding-top:var(--spacing-sections);padding-bottom:var(--spacing-sections);">
  {%- if section.settings.heading != blank -%}
    <p class="press-strip__heading">{{ section.settings.heading }}</p>
  {%- endif -%}
  <div class="press-strip__logos">
    {%- for block in section.blocks -%}
      <div class="press-strip__logo" {{ block.shopify_attributes }}>
        {%- if block.settings.logo -%}
          <img
            src="{{ block.settings.logo | image_url: width: 300 }}"
            alt="{{ block.settings.name | escape }}"
            loading="lazy"
            width="300"
            height="{{ 300 | divided_by: block.settings.logo.aspect_ratio | default: 100 }}"
          >
        {%- else -%}
          <span>{{ block.settings.name }}</span>
        {%- endif -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Press strip",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "As seen in" }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "logo", "label": "Logo" },
        { "type": "text", "id": "name", "label": "Name" }
      ]
    }
  ],
  "presets": [
    { "name": "Press strip" }
  ]
}
{% endschema %}
