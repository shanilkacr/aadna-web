<section class="featured-collection page-width"{% if section.settings.remove_top_padding %} style="padding-top:0;"{% endif %}>
  <div class="product-grid product-grid--large" style="--columns:{{ section.settings.columns }};">
    {%- liquid
      if section.settings.collection != blank
        assign collection = collections[section.settings.collection]
      else
        assign collection = collections.all
      endif
      assign count = section.settings.products_to_show
      if collection.handle == 'all'
        assign products = collection.products | sort: 'created_at' | reverse
      else
        assign products = collection.products
      endif
    -%}
    {%- if collection != blank and products.size > 0 -%}
      {%- for product in products limit: count -%}
        {% render 'product-card', product: product %}
      {%- endfor -%}
    {%- else -%}
      {%- for i in (1..count) -%}
        {% render 'product-card', fallback_image: section.settings.placeholder_images %}
      {%- endfor -%}
    {%- endif -%}
  </div>

  {%- if section.settings.show_view_all and collection != blank -%}
    <div class="featured-collection__view-all">
      <a href="{{ collection.url }}" class="button button--secondary">{{ 'collections.general.view_all' | t }}</a>
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Leave empty to show all products, newest first." },
    { "type": "text", "id": "placeholder_images", "label": "Fallback image URL (used when no collection is selected)" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "default": 3, "label": "Products to show" },
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "default": 3, "label": "Columns (desktop)" },
    { "type": "checkbox", "id": "show_view_all", "default": false, "label": "Show \"View all\" button" },
    { "type": "checkbox", "id": "remove_top_padding", "default": false, "label": "Remove top padding" }
  ],
  "presets": [
    { "name": "Featured collection" }
  ]
}
{% endschema %}
