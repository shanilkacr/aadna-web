<section class="newsletter-banner" style="background-color:{{ section.settings.background }};">
  <div class="page-width newsletter-banner__inner">
    <h2>{% if section.settings.heading != blank %}{{ section.settings.heading }}{% else %}{{ 'general.newsletter.heading' | t }}{% endif %}</h2>
    <p>{% if section.settings.text != blank %}{{ section.settings.text }}{% else %}{{ 'general.newsletter.text' | t }}{% endif %}</p>
    {% form 'customer', class: 'newsletter-form' %}
      {%- if form.posted_successfully? -%}
        <p class="newsletter-form__success">{{ 'general.newsletter.success' | t }}</p>
      {%- endif -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="newsletter-form__row">
        <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" required>
        <button type="submit" class="text-link">{{ 'general.newsletter.submit' | t }}</button>
      </div>
    {% endform %}
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "text", "label": "Text" },
    { "type": "color", "id": "background", "label": "Background", "default": "#F2ECE2" }
  ],
  "presets": [
    { "name": "Newsletter" }
  ]
}
{% endschema %}
