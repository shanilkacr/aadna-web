{%- comment -%}
  Editable image gallery for pages such as Design Your Own.
  Merchants add or reorder images from the theme editor.
{%- endcomment -%}
{%- if section.blocks.size > 0 -%}
  <div class="image-gallery{% if section.settings.heading != blank %} image-gallery--has-heading{% endif %}" {{ section.shopify_attributes }}>
    {%- if section.settings.heading != blank -%}
      <div class="image-gallery__header page-width">
        <h2 class="image-gallery__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="image-gallery__subheading">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="image-gallery__grid page-width" data-image-gallery>
      {%- for block in section.blocks -%}
        {%- if block.type == 'image' -%}
          <figure class="image-gallery__item" {{ block.shopify_attributes }}>
            <div class="image-gallery__media">
              {%- if block.settings.image != blank -%}
                <img
                  src="{{ block.settings.image | image_url: width: 900 }}"
                  srcset="{{ block.settings.image | image_url: width: 450 }} 450w, {{ block.settings.image | image_url: width: 900 }} 900w"
                  sizes="(max-width: 900px) 50vw, 25vw"
                  alt="{{ block.settings.caption | default: block.settings.image.alt | escape }}"
                  width="900"
                  height="{{ 900 | divided_by: block.settings.image.aspect_ratio | default: 1 }}"
                  loading="lazy"
                >
              {%- elsif block.settings.fallback_image != blank -%}
                <img
                  src="{{ block.settings.fallback_image }}"
                  alt="{{ block.settings.caption | escape }}"
                  width="900"
                  height="1125"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'image-gallery__placeholder' }}
              {%- endif -%}
            </div>
            {%- if block.settings.caption != blank -%}
              <figcaption class="image-gallery__caption">{{ block.settings.caption }}</figcaption>
            {%- endif -%}
          </figure>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Image gallery",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Bespoke commissions"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "A selection of one-of-a-kind pieces crafted for our clients."
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "fallback_image",
          "label": "Fallback image URL",
          "info": "Used only until an image is selected above."
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image gallery"
    }
  ]
}
{% endschema %}
