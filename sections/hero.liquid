{%- if section.settings.banner_text != blank -%}
  <div class="hero-banner">{{ section.settings.banner_text }}</div>
{%- endif -%}

<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image_mobile != blank -%}
      <picture>
        <source media="(max-width: 749px)" srcset="{{ section.settings.image_mobile | image_url: width: 900 }}">
        {%- if section.settings.image != blank -%}
          <img
            src="{{ section.settings.image | image_url: width: 1800 }}"
            srcset="{{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1400 }} 1400w, {{ section.settings.image | image_url: width: 1800 }} 1800w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
            sizes="100vw"
            alt="{{ section.settings.heading | escape }}"
            width="1800"
            height="{{ 1800 | divided_by: section.settings.image.aspect_ratio | default: 900 }}"
            loading="eager"
            fetchpriority="high"
          >
        {%- elsif section.settings.fallback_image != blank -%}
          <img src="{{ section.settings.fallback_image }}" alt="{{ section.settings.heading | escape }}" width="1800" height="900" loading="eager">
        {%- else -%}
          <div class="hero__placeholder" role="img" aria-label="{{ section.settings.heading | escape }}"></div>
        {%- endif -%}
      </picture>
    {%- else -%}
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1800 }}"
          srcset="{{ section.settings.image | image_url: width: 900 }} 900w, {{ section.settings.image | image_url: width: 1400 }} 1400w, {{ section.settings.image | image_url: width: 1800 }} 1800w, {{ section.settings.image | image_url: width: 2400 }} 2400w"
          sizes="100vw"
          alt="{{ section.settings.heading | escape }}"
          width="1800"
          height="{{ 1800 | divided_by: section.settings.image.aspect_ratio | default: 900 }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- elsif section.settings.fallback_image != blank -%}
        <img src="{{ section.settings.fallback_image }}" alt="{{ section.settings.heading | escape }}" width="1800" height="900" loading="eager">
      {%- else -%}
        <div class="hero__placeholder" role="img" aria-label="{{ section.settings.heading | escape }}"></div>
      {%- endif -%}
    {%- endif -%}
  </div>

  <div class="hero__content">
    {%- if section.settings.heading != blank -%}<h1 class="hero__heading">{{ section.settings.heading }}</h1>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="button button--outline-white">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "settings": [
    { "type": "text", "id": "banner_text", "label": "Banner text", "default": "Islandwide free delivery" },
    { "type": "image_picker", "id": "image", "label": "Image (desktop)" },
    { "type": "image_picker", "id": "image_mobile", "label": "Image (mobile)" },
    { "type": "text", "id": "fallback_image", "label": "Fallback image URL (used until an image is selected above)" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" }
  ],
  "presets": [
    {
      "name": "Hero",
      "settings": {
        "heading": "Flamboyant handcrafted jewellery",
        "button_label": "Shop the collection",
        "button_link": "/collections/all"
      }
    }
  ]
}
{% endschema %}
