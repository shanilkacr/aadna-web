<section class="story-page page-width">
  <div class="collection__header">
    {%- liquid
      assign hero_title = section.settings.hero_title
      if hero_title == blank
        assign hero_title = page.title
      endif
    -%}
    <h1>{{ hero_title }}</h1>
    {%- if section.settings.hero_subtitle != blank -%}
      <div class="collection__description">{{ section.settings.hero_subtitle }}</div>
    {%- endif -%}
  </div>

  {%- assign row_index = 0 -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'row' -%}
        {%- assign row_parity = row_index | modulo: 2 -%}
        {%- assign row_index = row_index | plus: 1 -%}
        <div class="story-page__row{% if row_parity == 1 %} story-page__row--reverse{% endif %}" {{ block.shopify_attributes }}>
          <div class="story-page__media{% if block.settings.vimeo_id != blank %} story-page__media--video{% endif %}">
            {%- if block.settings.vimeo_id != blank -%}
              <div class="story-page__media-video">
                <iframe
                  src="https://player.vimeo.com/video/{{ block.settings.vimeo_id }}?background=1&autoplay=1&muted=1&loop=1&playsinline=1"
                  frameborder="0"
                  allow="autoplay; fullscreen"
                  loading="lazy"
                  title="{{ block.settings.heading | escape }}"
                ></iframe>
              </div>
            {%- elsif block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 1200 }}"
                alt="{{ block.settings.heading | escape }}"
                loading="lazy"
                width="1200"
                height="{{ 1200 | divided_by: block.settings.image.aspect_ratio | default: 1200 }}"
              >
            {%- elsif block.settings.fallback_image != blank -%}
              <img src="{{ block.settings.fallback_image }}" alt="{{ block.settings.heading | escape }}" loading="lazy" width="1200" height="1500">
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'story-page__placeholder' }}
            {%- endif -%}
          </div>
          <div class="story-page__text">
            {%- if block.settings.quote != blank -%}
              <p class="story-page__quote">&ldquo;{{ block.settings.quote }}&rdquo;</p>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h2>{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="story-page__body">{{ block.settings.body }}</div>
            {%- endif -%}
            {%- if block.settings.attribution != blank -%}
              <p class="story-page__attribution">&mdash; {{ block.settings.attribution }}</p>
            {%- endif -%}
          </div>
        </div>
      {%- when 'statement' -%}
        <div class="story-page__statement" {{ block.shopify_attributes }}>
          <div class="story-page__statement-text">
            {%- if block.settings.heading != blank -%}
              <h2>{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="story-page__body">{{ block.settings.body }}</div>
            {%- endif -%}
          </div>
          <div class="story-page__statement-video">
            {%- if block.settings.vimeo_id != blank -%}
              <iframe
                src="https://player.vimeo.com/video/{{ block.settings.vimeo_id }}?background=1&autoplay=1&muted=1&loop=1&playsinline=1"
                frameborder="0"
                allow="autoplay; fullscreen"
                loading="lazy"
                title="{{ block.settings.heading | escape }}"
              ></iframe>
            {%- endif -%}
          </div>
        </div>
    {%- endcase -%}
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "Story page",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "hero_title",
      "label": "Page title",
      "default": "Jewellery with a story, from the paradise island"
    },
    {
      "type": "text",
      "id": "hero_subtitle",
      "label": "Subtitle"
    }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "Image + text row",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image URL", "info": "Used only until an image is picked above." },
        { "type": "text", "id": "vimeo_id", "label": "Vimeo video ID", "info": "If set, replaces the image with a background video. The number from the Vimeo URL, e.g. 870539693." },
        { "type": "text", "id": "quote", "label": "Quote (optional)" },
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "body", "label": "Body text" },
        { "type": "text", "id": "attribution", "label": "Attribution" }
      ]
    },
    {
      "type": "statement",
      "name": "Closing statement",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading" },
        { "type": "richtext", "id": "body", "label": "Text" },
        { "type": "text", "id": "vimeo_id", "label": "Vimeo video ID", "info": "The number from the Vimeo URL, e.g. 870539693." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Story page",
      "blocks": [
        {
          "type": "row",
          "settings": {
            "quote": "With each stone and each piece of jewellery we try to tell a story",
            "body": "<p>The founder and designer, Kalpani, is truly inspired to make her clients feel like the owner and the custodian of each stone and piece of jewellery. At AADNA, the team is dedicated to creating unique jewellery influenced by the Sri Lankan heritage and using excellent local craftsmanship.</p><p><em>‘It’s like writing a poem or finishing a beautiful painting.. Only I do it with natural stones and metal..’</em></p>",
            "attribution": "Kalpani Nandaratne"
          }
        },
        {
          "type": "row",
          "settings": {
            "heading": "Handcrafted to perfection",
            "vimeo_id": "870539693",
            "body": "<p>AADNA is the result of a wonder luscious journey of a Sri Lankan designer. Following her heart’s deep calling to create something magnificent, passionate and long lasting, she set forth wandering around the paradise island. As with many other artists she experimented with many muses only to find her soul resting on the great craftsmanship of jewellery design.</p>",
            "attribution": "Kalpani Nandaratne"
          }
        }
      ]
    }
  ]
}
{% endschema %}
