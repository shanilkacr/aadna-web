<section class="full-width-image">
  {%- if section.settings.video != blank -%}
    {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false, class: 'full-width-image__media' }}
  {%- elsif section.settings.fallback_video != blank -%}
    <video class="full-width-image__media" src="{{ section.settings.fallback_video }}" autoplay muted loop playsinline aria-label="{{ section.settings.alt | escape }}"></video>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Full width image",
  "settings": [
    { "type": "video", "id": "video", "label": "Video" },
    { "type": "text", "id": "fallback_video", "label": "Fallback video URL (used until a video is selected above)" },
    { "type": "text", "id": "alt", "label": "Accessible label", "default": "AADNA campaign" }
  ],
  "presets": [
    {
      "name": "Full width image",
      "settings": {
        "alt": "AADNA campaign"
      }
    }
  ]
}
{% endschema %}
