<section class="full-width-image">
  {%- if section.settings.image != blank -%}
    <img
      src="{{ section.settings.image | image_url: width: 2000 }}"
      alt="{{ section.settings.alt | escape }}"
      width="2000"
      height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | default: 1125 }}"
      loading="lazy"
    >
  {%- elsif section.settings.fallback_image != blank -%}
    <img src="{{ section.settings.fallback_image }}" alt="{{ section.settings.alt | escape }}" width="2000" height="1125" loading="lazy">
  {%- else -%}
    <img src="{{ 'fashion-week-campaign.png' | asset_url }}" alt="{{ section.settings.alt | default: shop.name | escape }}" width="2000" height="1125" loading="lazy">
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Full width image",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "fallback_image", "label": "Fallback image URL (used until an image is selected above)" },
    { "type": "text", "id": "alt", "label": "Alt text" }
  ],
  "default": {
    "settings": {
      "alt": "AADNA campaign"
    }
  },
  "presets": [
    {
      "name": "Full width image",
      "settings": {
        "alt": "AADNA campaign"
      }
    }
  ]
}
{% endschema %}
