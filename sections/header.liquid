{%- if template.name == 'index' -%}
  <header class="site-header site-header--transparent" data-header-transparent>
    {% render 'header-content', variant: 'transparent' %}
  </header>
  <header class="site-header site-header--solid" data-header-solid>
    {% render 'header-content', variant: 'solid' %}
  </header>
{%- else -%}
  <header class="site-header site-header--default" data-header>
    {% render 'header-content', variant: 'default' %}
  </header>
{%- endif -%}

{% render 'menu-drawer', menu: section.settings.menu, mega_trigger: section.settings.mega_menu_trigger %}

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "main-menu"
    },
    {
      "type": "header",
      "content": "Mega menu"
    },
    {
      "type": "text",
      "id": "mega_menu_trigger",
      "label": "Trigger menu item",
      "info": "Top-level menu item that opens the mega menu on hover (must match its title exactly).",
      "default": "Shop"
    },
    {
      "type": "paragraph",
      "content": "Product types in the mega menu are loaded from your store's product type filter. If unavailable, Earrings, Necklace, Rings, Cufflinks, Bangle, and Charms are shown as links to /collections/all with the matching filter."
    }
  ],
  "blocks": [
    {
      "type": "mega_tile",
      "name": "Mega menu tile",
      "limit": 4,
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection", "info": "If left empty, falls back to the store's collections automatically." },
        { "type": "text", "id": "label", "label": "Label override" },
        { "type": "url", "id": "link", "label": "Link override" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image URL" }
      ]
    }
  ]
}
{% endschema %}
