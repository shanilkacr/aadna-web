<section class="collection-list">
  <div class="collection-list__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = collections[block.settings.collection]
        assign image_url = block.settings.fallback_image
      -%}
      <div class="collection-list__item" {{ block.shopify_attributes }}>
        <div class="collection-list__media">
          {%- if block.settings.video != blank -%}
            {{ block.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, controls: false }}
          {%- elsif block.settings.image != blank -%}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.title | default: collection.title | escape }}"
              loading="lazy"
              width="1200"
              height="{{ 1200 | divided_by: block.settings.image.aspect_ratio | default: 1200 }}"
            >
          {%- elsif block.settings.collection != blank and collection.featured_image -%}
            <img
              src="{{ collection.featured_image | image_url: width: 1200 }}"
              alt="{{ collection.title | escape }}"
              loading="lazy"
              width="1200"
              height="{{ 1200 | divided_by: collection.featured_image.aspect_ratio | default: 1200 }}"
            >
          {%- elsif image_url != blank and image_url contains '://' -%}
            <img src="{{ image_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="1200" height="1200">
          {%- elsif image_url != blank -%}
            <img src="{{ image_url | asset_url }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="1200" height="1200">
          {%- endif -%}
        </div>
        <div class="collection-list__overlay"></div>
        <div class="collection-list__content">
          <h2 class="collection-list__title">{{ block.settings.title | default: collection.title }}</h2>
          <a href="{{ collection.url | default: '#' }}" class="collection-list__cta">{{ 'collections.general.explore' | t }}</a>
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "video", "id": "video", "label": "Video (overrides image)" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image (only used until image is set)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection", "settings": { "title": "Isla", "fallback_image": "collection-isla.webp" } },
        { "type": "collection", "settings": { "title": "Teardrop", "fallback_image": "collection-teardrop.webp" } },
        { "type": "collection", "settings": { "title": "Athena", "fallback_image": "collection-athena.webp" } },
        { "type": "collection", "settings": { "title": "Island Love", "fallback_image": "collection-island-love.webp" } }
      ]
    }
  ]
}
{% endschema %}
