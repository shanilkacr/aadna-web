<section class="collection-list">
  <div class="collection-list__grid">
    {%- for block in section.blocks -%}
      {%- liquid
        assign collection = collections[block.settings.collection]
      -%}
      <div {{ block.shopify_attributes }}>
        {%- render 'collection-card',
          collection: collection,
          title: block.settings.title,
          image: block.settings.image,
          video: block.settings.video,
          fallback_image: block.settings.fallback_image
        -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Collection list",
  "settings": [],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "text", "id": "title", "label": "Title override" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "video", "id": "video", "label": "Video (overrides image)" },
        { "type": "text", "id": "fallback_image", "label": "Fallback image (only used until image is set)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection list",
      "blocks": [
        { "type": "collection", "settings": { "title": "Isla", "fallback_image": "collection-isla.webp" } },
        { "type": "collection", "settings": { "title": "Teardrop", "fallback_image": "collection-teardrop.webp" } },
        { "type": "collection", "settings": { "title": "Athena", "fallback_image": "collection-athena.webp" } },
        { "type": "collection", "settings": { "title": "Island Love", "fallback_image": "collection-island-love.webp" } }
      ]
    }
  ]
}
{% endschema %}
