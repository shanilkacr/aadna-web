<footer class="site-footer">
  <div class="page-width site-footer__inner">
    <div class="site-footer__block site-footer__brand">
      {% render 'logo', variant: 'gold', class: 'site-footer__logo', width: 120 %}
      {%- if section.settings.tagline != blank -%}
        <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {% render 'social-icons' %}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="site-footer__block" {{ block.shopify_attributes }}>
          <p class="site-footer__heading">{{ block.settings.heading }}</p>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- elsif block.type == 'custom_links' -%}
        <div class="site-footer__block" {{ block.shopify_attributes }}>
          <p class="site-footer__heading">{{ block.settings.heading }}</p>
          <ul>
            {%- for i in (1..6) -%}
              {%- assign label_key = 'link_' | append: i | append: '_label' -%}
              {%- assign url_key = 'link_' | append: i | append: '_url' -%}
              {%- assign label = block.settings[label_key] -%}
              {%- assign url = block.settings[url_key] -%}
              {%- if label != blank -%}
                <li><a href="{{ url | default: '#' }}">{{ label }}</a></li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <div class="site-footer__block site-footer__newsletter">
      <p class="site-footer__heading">{{ 'general.newsletter.heading' | t }}</p>
      <p class="site-footer__text">{{ 'general.newsletter.text' | t }}</p>
      {% form 'customer', class: 'newsletter-form' %}
        {%- if form.posted_successfully? -%}
          <p class="newsletter-form__success">{{ 'general.newsletter.success' | t }}</p>
        {%- endif -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form__row">
          <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" required>
          <button type="submit">{{ 'general.newsletter.submit' | t }}</button>
        </div>
      {% endform %}
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="page-width site-footer__bottom-inner">
      <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.copyright' | t }}</p>
      <div class="site-footer__payment">
        {%- for type in shop.enabled_payment_types -%}
          {{ type | payment_type_svg_tag: class: 'payment-icon' }}
        {%- endfor -%}
      </div>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "She is a force of nature, she is everything you need." }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Support" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    },
    {
      "type": "custom_links",
      "name": "Custom links",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Support" },
        { "type": "header", "content": "Links" },
        { "type": "text", "id": "link_1_label", "label": "Link 1 label" },
        { "type": "url", "id": "link_1_url", "label": "Link 1 URL" },
        { "type": "text", "id": "link_2_label", "label": "Link 2 label" },
        { "type": "url", "id": "link_2_url", "label": "Link 2 URL" },
        { "type": "text", "id": "link_3_label", "label": "Link 3 label" },
        { "type": "url", "id": "link_3_url", "label": "Link 3 URL" },
        { "type": "text", "id": "link_4_label", "label": "Link 4 label" },
        { "type": "url", "id": "link_4_url", "label": "Link 4 URL" },
        { "type": "text", "id": "link_5_label", "label": "Link 5 label" },
        { "type": "url", "id": "link_5_url", "label": "Link 5 URL" },
        { "type": "text", "id": "link_6_label", "label": "Link 6 label" },
        { "type": "url", "id": "link_6_url", "label": "Link 6 URL" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Support", "menu": "footer-menu" } },
      { "type": "link_list", "settings": { "heading": "Need Help?", "menu": "need-help" } }
    ]
  }
}
{% endschema %}
