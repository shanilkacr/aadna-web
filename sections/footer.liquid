<footer class="site-footer">
  <div class="page-width site-footer__inner">
    <div class="site-footer__block site-footer__brand">
      {%- if settings.logo_alt -%}
        <img src="{{ settings.logo_alt | image_url: width: 300 }}" alt="{{ shop.name }}" width="120" height="{{ 120 | divided_by: settings.logo_alt.aspect_ratio | default: 120 }}" style="height:auto;">
      {%- elsif settings.logo -%}
        <img src="{{ settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}" width="120" height="{{ 120 | divided_by: settings.logo.aspect_ratio | default: 120 }}" style="height:auto;">
      {%- else -%}
        <img src="{{ 'logo-gold.png' | asset_url }}" alt="{{ shop.name }}" width="120" height="{{ 120 | times: 260 | divided_by: 800 }}" style="height:auto;">
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="site-footer__tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
      {% render 'social-icons' %}
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' -%}
        <div class="site-footer__block" {{ block.shopify_attributes }}>
          <p class="site-footer__heading">{{ block.settings.heading }}</p>
          <ul>
            {%- for link in block.settings.menu.links -%}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}
    {%- endfor -%}

    <div class="site-footer__block site-footer__newsletter">
      <p class="site-footer__heading">{{ 'general.newsletter.heading' | t }}</p>
      <p class="site-footer__text">{{ 'general.newsletter.text' | t }}</p>
      {% form 'customer', class: 'newsletter-form' %}
        {%- if form.posted_successfully? -%}
          <p class="newsletter-form__success">{{ 'general.newsletter.success' | t }}</p>
        {%- endif -%}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="newsletter-form__row">
          <input type="email" name="contact[email]" placeholder="{{ 'general.newsletter.placeholder' | t }}" required>
          <button type="submit">{{ 'general.newsletter.submit' | t }}</button>
        </div>
      {% endform %}
    </div>
  </div>

  <div class="page-width site-footer__bottom">
    <p>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ 'sections.footer.copyright' | t }}</p>
    <div class="site-footer__payment">
      {%- for type in shop.enabled_payment_types -%}
        {{ type | payment_type_svg_tag: class: 'payment-icon' }}
      {%- endfor -%}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "text", "id": "tagline", "label": "Tagline", "default": "She is a force of nature, she is everything you need." }
  ],
  "blocks": [
    {
      "type": "link_list",
      "name": "Link list",
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "Support" },
        { "type": "link_list", "id": "menu", "label": "Menu" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "link_list", "settings": { "heading": "Support" } },
      { "type": "link_list", "settings": { "heading": "Company" } }
    ]
  }
}
{% endschema %}
