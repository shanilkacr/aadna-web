<section class="cart-page page-width">
  <h1>{{ 'general.cart.title' | t }}</h1>

  {%- if cart.item_count == 0 -%}
    <p class="cart-page__empty">{{ 'general.cart.empty' | t }}</p>
    <a href="{{ routes.all_products_collection_url }}" class="button button--primary">{{ 'general.cart.continue_shopping' | t }}</a>
  {%- else -%}
    {%- form 'cart', cart, id: 'CartPageForm' -%}
      <table class="cart-page__table">
        <thead>
          <tr>
            <th>{{ 'general.cart.product' | t }}</th>
            <th>{{ 'general.cart.quantity' | t }}</th>
            <th>{{ 'general.cart.line_total' | t }}</th>
          </tr>
        </thead>
        <tbody>
          {%- for item in cart.items -%}
            <tr class="cart-page__row">
              <td class="cart-page__product">
                <a href="{{ item.url }}" class="cart-page__image">
                  {%- if item.image -%}<img src="{{ item.image | image_url: width: 200 }}" alt="{{ item.image.alt | escape }}" width="200" height="{{ 200 | divided_by: item.image.aspect_ratio | default: 250 }}">{%- endif -%}
                </a>
                <div>
                  <a href="{{ item.url }}">{{ item.product.title }}</a>
                  {%- if item.variant.title != 'Default Title' -%}<p>{{ item.variant.title }}</p>{%- endif -%}
                  {%- for property in item.properties -%}
                    {%- unless property.last == blank -%}
                      <p>{{ property.first }}: {{ property.last }}</p>
                    {%- endunless -%}
                  {%- endfor -%}
                  <p>{{ item.final_price | money }}</p>
                </div>
              </td>
              <td>
                <input type="number" name="updates[{{ forloop.index0 }}]" value="{{ item.quantity }}" min="0">
              </td>
              <td>{{ item.final_line_price | money }}</td>
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
      <button type="submit" name="update" class="button button--secondary">{{ 'general.cart.update' | t }}</button>
    {%- endform -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Cart items",
  "enabled_on": {
    "templates": ["cart"]
  },
  "settings": []
}
{% endschema %}
