<section class="search page-width">
  <h1>{{ 'general.search.title' | t }}</h1>

  <form action="{{ routes.search_url }}" method="get" role="search" class="search__form">
    <input
      type="search"
      name="q"
      value="{{ search.terms | escape }}"
      placeholder="{{ 'general.search.placeholder' | t }}"
      aria-label="{{ 'general.search.placeholder' | t }}"
    >
    <button type="submit" class="button button--secondary">{{ 'general.search.submit' | t }}</button>
  </form>

  {%- if search.performed -%}
    {%- if search.results_count == 0 -%}
      <p class="search__empty">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
    {%- else -%}
      <p class="search__count">{{ 'general.search.results_count' | t: count: search.results_count }}</p>
      {%- paginate search.results by 24 -%}
        <div class="product-grid" style="--columns:{{ section.settings.columns }};">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="pagination">
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="{% if part.title == paginate.current_page %}is-current{% endif %}">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Search results",
  "enabled_on": {
    "templates": ["search"]
  },
  "settings": [
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "default": 4, "label": "Columns (desktop)" }
  ]
}
{% endschema %}
