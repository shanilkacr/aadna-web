<section class="collection page-width">
  <div class="collection__header">
    <h1>{{ collection.title }}</h1>
    {%- if collection.description != blank -%}
      <div class="collection__description">{{ collection.description }}</div>
    {%- endif -%}
  </div>

  {%- if collection.products.size == 0 -%}
    <p class="collection__empty">{{ 'collections.general.no_products' | t }}</p>
  {%- else -%}
    {%- paginate collection.products by 24 -%}
      <div class="product-grid" style="--columns:{{ section.settings.columns }};">
        {%- for product in collection.products -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>

      {%- if paginate.pages > 1 -%}
        <nav class="pagination">
          {%- for part in paginate.parts -%}
            {%- if part.is_link -%}
              <a href="{{ part.url }}">{{ part.title }}</a>
            {%- else -%}
              <span class="{% if part.title == paginate.current_page %}is-current{% endif %}">{{ part.title }}</span>
            {%- endif -%}
          {%- endfor -%}
        </nav>
      {%- endif -%}
    {%- endpaginate -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Product grid",
  "settings": [
    { "type": "range", "id": "columns", "min": 2, "max": 5, "step": 1, "default": 4, "label": "Columns (desktop)" }
  ]
}
{% endschema %}
